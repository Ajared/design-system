{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "ajaRed Design System Tokens - Extracted from Figma",
  "color": {
    "primary": {
      "$type": "color",
      "default": { "$value": "#058c8c" },
      "dark": { "$value": "#046363" },
      "darker": { "$value": "#023b3b" },
      "light": { "$value": "#8ccaca" },
      "lighter": { "$value": "#b2dbdb" },
      "lightest": { "$value": "#e6f4f4" }
    },
    "accent": {
      "$type": "color",
      "terracotta": {
        "default": { "$value": "#a1665e" },
        "dark": { "$value": "#935d56" },
        "light": { "$value": "#d4b9b5" }
      },
      "gold": { "$value": "#d09958" },
      "orange": { "$value": "#ec9a29" },
      "purple": { "$value": "#9747ff" },
      "green": { "$value": "#138c05" }
    },
    "neutral": {
      "$type": "color",
      "black": { "$value": "#000000" },
      "900": { "$value": "#141414" },
      "800": { "$value": "#323232" },
      "700": { "$value": "#434343" },
      "600": { "$value": "#626262" },
      "500": { "$value": "#717171" },
      "400": { "$value": "#939393" },
      "300": { "$value": "#b6b6b6" },
      "200": { "$value": "#d9d9d9" },
      "100": { "$value": "#eeeeee" },
      "50": { "$value": "#f5f5f5" },
      "white": { "$value": "#ffffff" }
    },
    "semantic": {
      "$type": "color",
      "success": {
        "default": { "$value": "#61b258" },
        "light": { "$value": "#e7f3f4" }
      },
      "warning": {
        "default": { "$value": "#d6b739" },
        "light": { "$value": "#f7ebc6" }
      },
      "error": {
        "default": { "$value": "#8c1305" },
        "light": { "$value": "#ffa18a" }
      },
      "info": {
        "default": { "$value": "#71c5e6" },
        "light": { "$value": "#eaf6fb" }
      }
    },
    "background": {
      "$type": "color",
      "primary": { "$value": "#ffffff" },
      "secondary": { "$value": "#f7f8f7" },
      "tertiary": { "$value": "#f6f6f6" },
      "dark": { "$value": "#141414" },
      "teal": { "$value": "#058c8c" },
      "terracotta": { "$value": "#a1665e" }
    },
    "text": {
      "$type": "color",
      "primary": { "$value": "#323232" },
      "secondary": { "$value": "#626262" },
      "tertiary": { "$value": "#939393" },
      "inverse": { "$value": "#ffffff" },
      "dark": { "$value": "#141414" }
    },
    "border": {
      "$type": "color",
      "light": { "$value": "#e2e2e2" },
      "medium": { "$value": "#d9d9d9" },
      "dark": { "$value": "#b6b6b6" }
    }
  },
  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "primary": { "$value": ["iA Writer Quattro S", "system-ui", "-apple-system", "sans-serif"] },
      "secondary": { "$value": ["Inter", "system-ui", "-apple-system", "sans-serif"] },
      "accent": { "$value": ["Acme", "display", "sans-serif"] },
      "display": { "$value": ["Metal", "display", "sans-serif"] },
      "mono": { "$value": ["Roboto", "monospace"] }
    },
    "fontSize": {
      "$type": "dimension",
      "xs": { "$value": "8px" },
      "sm": { "$value": "12px" },
      "base": { "$value": "16px" },
      "md": { "$value": "18px" },
      "lg": { "$value": "20px" },
      "xl": { "$value": "24px" },
      "2xl": { "$value": "32px" },
      "3xl": { "$value": "36px" },
      "4xl": { "$value": "48px" },
      "5xl": { "$value": "64px" }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "normal": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "lineHeight": {
      "$type": "number",
      "tight": { "$value": 1.25 },
      "normal": { "$value": 1.5 },
      "relaxed": { "$value": 1.75 },
      "loose": { "$value": 2 }
    }
  },
  "spacing": {
    "$type": "dimension",
    "0": { "$value": "0" },
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "20px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "20": { "$value": "80px" },
    "24": { "$value": "96px" }
  },
  "borderRadius": {
    "$type": "dimension",
    "none": { "$value": "0" },
    "sm": { "$value": "2px" },
    "base": { "$value": "4px" },
    "md": { "$value": "6px" },
    "lg": { "$value": "8px" },
    "xl": { "$value": "12px" },
    "2xl": { "$value": "16px" },
    "3xl": { "$value": "24px" },
    "full": { "$value": "9999px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "color": "#00000008",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px"
      }
    },
    "base": {
      "$value": [
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "3px",
          "spread": "0px"
        },
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "2px",
          "spread": "-1px"
        }
      ]
    },
    "md": {
      "$value": [
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-1px"
        },
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "2px",
          "blur": "4px",
          "spread": "-2px"
        }
      ]
    },
    "lg": {
      "$value": [
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "10px",
          "blur": "15px",
          "spread": "-3px"
        },
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-4px"
        }
      ]
    },
    "xl": {
      "$value": [
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "20px",
          "blur": "25px",
          "spread": "-5px"
        },
        {
          "color": "#0000001a",
          "offsetX": "0px",
          "offsetY": "8px",
          "blur": "10px",
          "spread": "-6px"
        }
      ]
    },
    "2xl": {
      "$value": {
        "color": "#00000040",
        "offsetX": "0px",
        "offsetY": "25px",
        "blur": "50px",
        "spread": "-12px"
      }
    }
  },
  "zIndex": {
    "$type": "number",
    "base": { "$value": 0 },
    "dropdown": { "$value": 1000 },
    "sticky": { "$value": 1020 },
    "fixed": { "$value": 1030 },
    "modalBackdrop": { "$value": 1040 },
    "modal": { "$value": 1050 },
    "popover": { "$value": 1060 },
    "tooltip": { "$value": 1070 }
  },
  "transition": {
    "$type": "duration",
    "fast": { "$value": "150ms" },
    "base": { "$value": "250ms" },
    "slow": { "$value": "350ms" }
  }
}
